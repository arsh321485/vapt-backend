SECRET_KEY=replace-with-strong-secret
DEBUG=False

# MongoDB
MONGO_DB_URL=mongodb+srv://username:password@cluster.mongodb.net/vaptfix?retryWrites=true&w=majority
# Optional fallback key (used if MONGO_DB_URL is not set)
MONGO_URI=

# Email / SendGrid
SENDGRID_API_KEY=SG.xxxxx
DEFAULT_FROM_EMAIL=info@vaptfix.ai

# Google OAuth
GOOGLE_OAUTH2_CLIENT_ID=
GOOGLE_OAUTH2_CLIENT_SECRET=
GOOGLE_USERINFO_URL=https://www.googleapis.com/oauth2/v2/userinfo
GOOGLE_TOKENINFO_URL=https://oauth2.googleapis.com/tokeninfo

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=https://vaptbackend.secureitlab.com

# Slack OAuth
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_REDIRECT_URI=

# Jira OAuth
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:8000/api/admin/users/jira/callback/

# App URLs
FRONTEND_URL=https://vaptfix.ai
VAPTFIX_LOGIN_URL=https://vaptfix.ai/auth?tab=user
BACKEND_BASE_URL=https://vaptbackend.secureitlab.com

# reCAPTCHA
RECAPTCHA_SECRET_KEY=
